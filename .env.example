# העתק לערכים אמיתיים ב-Render → Environment (אל תעלה את הקובץ הזה עם ערכים אמיתיים)

# הטוקן מ-BotFather
BOT_TOKEN=

# כתובת ה-Web app של Apps Script (מסתיימת ב-/exec)
GAS_URL=

# אותו סוד שמופיע בתוך Code.gs (const SECRET)
